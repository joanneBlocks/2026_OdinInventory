<%- include('../partials/header') %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Items</h1>
  <a href="/items/new"
     class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition">
    + New item
  </a>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-gray-50 border-b border-gray-200 text-left text-gray-500 uppercase tracking-wide text-xs">
        <th class="px-5 py-3">Name</th>
        <th class="px-5 py-3">Category</th>
        <th class="px-5 py-3">Supplier</th>
        <th class="px-5 py-3">Price</th>
        <th class="px-5 py-3">Stock</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% items.forEach(item => { %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-5 py-4 font-medium">
            <a href="/items/<%= item.id %>"
               class="text-blue-600 hover:underline">
              <%= item.name %>
            </a>
          </td>
          <td class="px-5 py-4 text-gray-600">
            <% if (item.category_name) { %>
              <span class="bg-blue-50 text-blue-700 text-xs font-medium px-2 py-1 rounded-full">
                <%= item.category_name %>
              </span>
            <% } else { %>
              <span class="text-gray-400">—</span>
            <% } %>
          </td>
          <td class="px-5 py-4 text-gray-600"><%= item.supplier_name || '—' %></td>
          <td class="px-5 py-4 font-medium text-gray-900">$<%= item.price %></td>
          <td class="px-5 py-4">
            <% if (item.quantity < 10) { %>
              <span class="bg-red-50 text-red-600 text-xs font-medium px-2 py-1 rounded-full">
                <%= item.quantity %> low
              </span>
            <% } else { %>
              <span class="text-gray-700"><%= item.quantity %></span>
            <% } %>
          </td>
          <td class="px-5 py-4 text-right flex items-center justify-end gap-3">
            <a href="/items/<%= item.id %>/edit"
               class="text-gray-500 hover:text-gray-900 text-sm transition">Edit</a>
            <form action="/items/<%= item.id %>/delete" method="POST"
              style="display:inline"
              onsubmit="return confirm('Are you sure you want to delete <%= item.name %>?')">
              <button type="submit"
                class="text-red-500 hover:text-red-700 text-sm transition">
                Delete
              </button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>