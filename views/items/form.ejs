<%- include('../partials/header') %>

<div class="mb-6">
  <a href="/items" class="text-sm text-gray-500 hover:text-gray-700 transition">&larr; Back to items</a>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 max-w-2xl mx-auto">
  <h1 class="text-2xl font-semibold text-gray-900 mb-6">
    <%= item ? 'Edit item' : 'New item' %>
  </h1>

  <form action="<%= item ? `/items/${item.id}/update` : '/items' %>" method="POST"
        class="flex flex-col gap-5">

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
      <input type="text" name="name" required
        value="<%= item ? item.name : '' %>"
        class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
      <textarea name="description" rows="3"
        class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"><%= item ? item.description : '' %></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Price</label>
        <input type="number" name="price" step="0.01" min="0" required
          value="<%= item ? item.price : '' %>"
          class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
        <input type="number" name="quantity" min="0"
          value="<%= item ? item.quantity : 0 %>"
          class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
        <select name="category_id"
          class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">— none —</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>"
              <%= item && item.category_id == c.id ? 'selected' : '' %>>
              <%= c.name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Supplier</label>
        <select name="supplier_id"
          class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">— none —</option>
          <% suppliers.forEach(s => { %>
            <option value="<%= s.id %>"
              <%= item && item.supplier_id == s.id ? 'selected' : '' %>>
              <%= s.name %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-5 mt-2">
      <label class="block text-sm font-medium text-gray-700 mb-1">Admin password</label>
      <input type="password" name="admin_password" required
        placeholder="Required to save changes"
        class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 mb-4">
      <div class="flex gap-3">
        <button type="submit"
          class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-6 py-2 rounded-lg transition">
          <%= item ? 'Save changes' : 'Create item' %>
        </button>
        <a href="/items"
          class="text-sm font-medium px-6 py-2 rounded-lg border border-gray-200 hover:bg-gray-50 transition">
          Cancel
        </a>
      </div>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>