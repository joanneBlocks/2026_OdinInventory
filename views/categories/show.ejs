<%- include('../partials/header') %>

<div class="mb-6">
  <a href="/categories" class="text-sm text-gray-500 hover:text-gray-700 transition">&larr; Back to categories</a>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 max-w-2xl mx-auto">
  <div class="flex items-start justify-between mb-4">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900 mb-1"><%= category.name %></h1>
      <p class="text-gray-500 text-sm"><%= category.description || 'No description.' %></p>
    </div>
    <div class="flex gap-3">
      <a href="/categories/<%= category.id %>/edit"
         class="text-sm font-medium px-4 py-2 rounded-lg border border-gray-200 hover:bg-gray-50 transition">
        Edit
      </a>
      <form action="/categories/<%= category.id %>/delete" method="POST"
        onsubmit="return confirm('Are you sure you want to delete <%= category.name %>?')">
        <button type="submit"
          class="text-sm font-medium px-4 py-2 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition">
          Delete
        </button>
      </form>
    </div>
  </div>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3 mt-4">
      <%= error %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>