<%- include('../partials/header') %>

<div class="mb-6">
  <a href="/suppliers" class="text-sm text-gray-500 hover:text-gray-700 transition">&larr; Back to suppliers</a>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 max-w-2xl mx-auto">
  <h1 class="text-2xl font-semibold text-gray-900 mb-6">
    <%= supplier ? 'Edit supplier' : 'New supplier' %>
  </h1>

  <form action="<%= supplier ? `/suppliers/${supplier.id}/update` : '/suppliers' %>" method="POST"
        class="flex flex-col gap-5">

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
      <input type="text" name="name" required
        value="<%= supplier ? supplier.name : '' %>"
        class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
      <input type="email" name="email"
        value="<%= supplier ? supplier.email : '' %>"
        class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
      <input type="text" name="phone"
        value="<%= supplier ? supplier.phone : '' %>"
        class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
    </div>

    <div class="flex gap-3 pt-2">
      <button type="submit"
        class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-6 py-2 rounded-lg transition">
        <%= supplier ? 'Save changes' : 'Create supplier' %>
      </button>
      <a href="/suppliers"
        class="text-sm font-medium px-6 py-2 rounded-lg border border-gray-200 hover:bg-gray-50 transition">
        Cancel
      </a>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>